# Copy this file to .env and fill in the values for local development.
# Never commit .env — it is listed in .gitignore.
#
# Production secrets are set with:
#   bunx wrangler secret put CALLBACK_URL
#   bunx wrangler secret put SHARED_SECRET

# URL that the workflow POSTs results back to.
CALLBACK_URL=https://your-callback-url.example.com/webhook

# HMAC-SHA256 shared secret used to sign/verify inbound requests and outbound callbacks.
# Generate with: openssl rand -hex 32
SHARED_SECRET=replace-with-a-random-32-byte-hex-string

# ── Integration test overrides ────────────────────────────────────────────────
# These are only used by callback-staging.spec.ts.

# URL that the staging workflow POSTs results back to.
# Use https://webhook.site to get a free unique URL for local testing.
TEST_CALLBACK_URL=https://webhook.site/abcd1234

# HMAC-SHA256 shared secret used to sign outbound callbacks in tests.
# Can be any string for local testing; use a real secret for staging.
TEST_SHARED_SECRET=replace-with-a-random-32-byte-hex-string

# OpenRouter API key used in staging integration tests.
TEST_OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
